<%- include("admin-topbar.ejs") %>

<div class="container-fluid">
  <div class="row">
    <div class="col-12 text-center">
      <h1 class="h3 mb-4">Courses</h1>
    </div>
    <div class="col-12 text-start">
      <button
        class="btn btn-primary"
        type="button"
        data-bs-toggle="collapse"
        data-bs-target="#collapseExample"
        aria-expanded="false"
        aria-controls="collapseExample"
      >
        Add courses
      </button>
    </div>
    <div class="col-12 mt-3">
      <div class="collapse" id="collapseExample">
        <div class="card card-body">
          <form
            action="/save-courses"
            method="POST"
            enctype="multipart/form-data"
          >
            <div class="row">
              <div class="col-12 mb-3">
                <label for="courseName" class="form-label">Course Name</label>
                <input
                  type="text"
                  name="courses_name"
                  class="form-control"
                  placeholder="Enter Course Name"
                  id="courseName"
                  required
                />
              </div>

              <div class="col-md-6 mb-3">
                <label for="coursePhoto" class="form-label">Course Photo</label>
                <input
                  type="file"
                  class="form-control"
                  name="courses_photo"
                  placeholder="Choose a photo"
                  id="coursePhoto"
                  required
                />
              </div>

              <div class="col-md-6 mb-3">
                <label for="courseTrainer" class="form-label"
                  >Course Trainer</label
                >
                <input
                  type="text"
                  class="form-control"
                  name="courses_trainner"
                  placeholder="Enter Course Trainer"
                  id="courseTrainer"
                  required
                />
              </div>

              <div class="col-md-6 mb-3">
                <label for="courseLang" class="form-label"
                  >Course Language</label
                >
                <input
                  type="text"
                  class="form-control"
                  name="courses_language"
                  placeholder="Enter Course Language"
                  id="courseLang"
                  required
                />
              </div>

              <div class="col-md-6 mb-3">
                <label for="courseDesc" class="form-label"
                  >Course Duration</label
                >
                <input
                  type="number"
                  class="form-control"
                  name="courses_duration"
                  placeholder="Enter Course Duration"
                  id="courseDesc"
                  required
                />
              </div>

              <div class="col-md-6 mb-3">
                <label for="coursePrice" class="form-label">Course Price</label>
                <input
                  type="number"
                  class="form-control"
                  name="courses_price"
                  placeholder="Enter Course Price"
                  id="coursePrice"
                  required
                />
              </div>

              <div class="col-12 mb-3 text-center">
                <button type="submit" class="btn btn-success">
                  Add Course
                </button>
              </div>
            </div>
          </form>
        </div>
      </div>
    </div>
    <div class="col-12 mt-3">
      <table class="table table-hover table-bordered">
        <thead class="text-center">
          <tr>
            <th scope="col">Sr.No</th>
            <th scope="col">Name</th>
            <th scope="col">Photo</th>
            <th scope="col">Trainer</th>
            <th scope="col">Language</th>
            <th scope="col">Duration</th>
            <th scope="col">Price</th>
            <th scope="col">Action</th>
          </tr>
        </thead>

        <tbody>
          <% if (Array.isArray(courseslist) && courseslist.length) { %> <% for
          (var i=0; i < courseslist.length; i++) { %>
          <tr>
            <td class="text-center"><%= i + 1 %></td>

            <td><%= courseslist[i].courses_name.length > 30 
                  ? courseslist[i].courses_name.substring(0, 30) + "..." 
                  : courseslist[i].courses_name %>
            </td>


            <td>
              <% if (courseslist[i].courses_photo) { %>
              <img
                src="/uploads/<%= courseslist[i].courses_photo %>"
                alt="Course Photo"
                width="60"
                height="60"
              />
              <% } else { %> N/A <% } %>
            </td>

           <td>
              <%= courseslist[i].courses_trainner.length > 30 
                    ? courseslist[i].courses_trainner.substring(0, 30) + "..." 
                    : courseslist[i].courses_trainner %>
            </td>

            <td><%= courseslist[i].courses_language %></td>
            <td><%= courseslist[i].courses_duration %>+ Hours</td>
            <td>&#8377; <%= courseslist[i].courses_price %></td>

            <td class="text-center">
              <a 
                href="/edit-course/<%= courseslist[i].courses_id %>"
                class="btn btn-warning btn-sm"
              >
                <i class="bi bi-pencil-square"></i>
              </a>

              <a
                href="/delete-course/<%= courseslist[i].courses_id %>"
                onclick="return confirm('Are you sure you want to delete this course?')"
                class="btn btn-danger btn-sm"
              >
                <i class="bi bi-trash"></i>
              </a>
            </td>
          </tr>
          <% } %> <% } else { %>
          <tr>
            <td colspan="8" class="text-center">No courses available.</td>
          </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>

  <%- include("admin-footer.ejs") %>
</div>
