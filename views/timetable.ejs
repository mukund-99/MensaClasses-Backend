<%- include("admin-topbar.ejs") %>
<div class="container-fluid py-4">
  <div class="row mb-3">
    <div class="col-12">
      <h2 class="text-center">Time Table</h2>
    </div>
  </div>

  <div class="row mb-4">
    <div class="col-12 d-flex justify-content-between align-items-center">
      <p class="mb-0">
        <a class="btn btn-primary" data-bs-toggle="collapse" href="#collapseExample" role="button" aria-expanded="false" aria-controls="collapseExample">
          Add Subject
        </a>
      </p>
    </div>
  </div>

  <div class="collapse" id="collapseExample">
    <div class="card card-body mb-4">
      <form action="/save-subjects" method="post" enctype="multipart/form-data" class="container-fluid">
        <div class="row g-3">
          <div class="col-12 col-md-6">
            <label for="subjectName" class="form-label">Subject Name:</label>
            <input type="text" name="subject_name" class="form-control" placeholder="Enter subject name" id="subjectName" required />
          </div>

          <div class="col-12 col-md-6">
            <label for="subjectDescription" class="form-label">Subject Description:</label>
            <input type="text" name="subject_description" class="form-control" placeholder="Enter subject description" id="subjectDescription" required />
          </div>

          <div class="col-12 col-md-6">
            <label for="subjectImage" class="form-label">Subject Image:</label>
            <input type="file" name="subject_image" class="form-control" placeholder="Enter subject image" id="subjectImage" accept="image/*" required />
          </div>

          <div class="col-12 text-center">
              <button type="submit" class="btn btn-success">Save Subject</button>
          </div>
        </div>
      </form>
    </div>
  </div>

  <div class="container-fluid">
    <div class="row">
      <div class="col-12">
        <table class="table table-bordered table-hover">
          <thead>
            <tr>
              <th class="text-center">ID</th>
              <th>Subject Name</th>
              <th>Subject Description</th>
              <th class="text-center">Subject Image</th>
              <th class="text-center">Action</th>
            </tr>
          </thead>
          <tbody>
            <% for(var i=0;i<subjects.length;i++) { %>
            <tr>
              <td class="text-center"><%= i+1 %></td>
              <td><%= subjects[i].subject_name %></td>
              <td><%= subjects[i].subject_description %></td>
              <td class="text-center"><img src="/<%= subjects[i].subject_image %>" alt="Subject Image" class="img-fluid" style="max-height: 50px;"></td>
              <td class="text-center">
                <a class="btn btn-warning btn-sm" href="/edit-subject/<%= subjects[i].subject_id %>"><i class="bi bi-pencil"></i></a>
                <a class="btn btn-danger btn-sm" onclick="return confirm('Are you sure you want to delete this subject?')" href="/delete-subject/<%= subjects[i].subject_id %>"><i class="bi bi-trash"></i></a>
              </td>
            </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

<%- include("admin-footer.ejs") %>