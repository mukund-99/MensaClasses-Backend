<%- include("admin-topbar.ejs") %>

<div class="container-fluid py-4">
  <div class="row">
    <div class="col-12">
      <h2 class="text-center mb-4">Edit Result</h2>
    </div>
  </div>

  <div class="row">
    <div class="col-12">

      <form action="/update-result" method="POST">
        <input type="hidden" name="result_id" value="<%= resultone[0].result_id %>">

        <div class="row">

          <div class="col-md-6 mb-3">
            <label for="result_name" class="form-label">Result Name</label>
            <input 
              type="text" 
              class="form-control" 
              id="result_name" 
              name="result_name" 
              value="<%= resultone[0].result_name %>" 
              required
            >
          </div>

          <div class="col-md-6 mb-3">
            <label for="result_rank_title" class="form-label">Result Title</label>
            <input 
              type="text" 
              class="form-control" 
              id="result_rank_title" 
              name="result_rank_title" 
              value="<%= resultone[0].result_rank_title %>" 
              required
            >
          </div>

          <div class="col-md-6 mb-3">
            <label>Result Image:</label>
            <input 
              type="file" 
              class="form-control" 
              id="result_image" 
              name="result_image" 
            >
            <small class="form-text text-muted">
              Please upload a valid image file (jpg, jpeg, png).
            </small>
          </div>

          <div class="col-md-6 mb-3">
            <img src="/uploads/<%= resultone[0].result_image %>" alt="Result Image" width="150" height="90">
          </div>

          <div class="col-md-6 mb-3">
            <label>Result Category:</label>
            <select class="form-control" id="result_category" name="result_category" required>

              <option value="toppers" 
                <%= resultone[0].result_category === "toppers" ? "selected" : "" %>>
                Toppers
              </option>

              <option value="rankHolders" 
                <%= resultone[0].result_category === "rankHolders" ? "selected" : "" %>>
                Rank Holders
              </option>

            </select>
          </div>



          <div class="col-12 text-center mt-3">
            <button type="submit" class="btn btn-primary px-5">Update Result</button>
          </div>

        </div>
      </form>

    </div>
  </div>
</div>

<%- include("admin-footer.ejs") %>
