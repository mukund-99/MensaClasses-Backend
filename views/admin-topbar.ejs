<!doctype html>
<html lang="en">

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Classroom Admin Dashboard</title>
  <!-- Bootstrap CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
  <style>
    :root {
      --sidebar-w: 250px;
      --accent: #6f42c1;
      /* purple */
      --muted: #6c757d;
      --card-radius: 12px;
      --bg: #f6f7fb;
    }

    html,
    body {
      height: 100%
    }

    body {
      background: var(--bg);
      font-family: system-ui, -apple-system, "Segoe UI", Roboto, "Helvetica Neue", Arial;
    }

    /* SIDEBAR */
    .sidebar {
      width: var(--sidebar-w);
      min-height: 100vh;
      background: linear-gradient(180deg, #3b185f 0%, #5b2fa7 100%);
      color: #fff;
      padding: 1.25rem 0.8rem;
      position: relative;
    }

    .brand {
      display: flex;
      align-items: center;
      gap: .6rem;
      padding: 0 .3rem;
      margin-bottom: 1.25rem
    }

    .logo {
      width: 44px;
      height: 44px;
      border-radius: 10px;
      background: linear-gradient(135deg, #9f7aea, #06b6d4);
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 700
    }

    .sidebar .nav-link {
      color: rgba(255, 255, 255, 0.95);
      border-radius: 10px;
      padding: .6rem .8rem;
      margin-bottom: .35rem
    }

    .sidebar .nav-link.active,
    .sidebar .nav-link:hover {
      background: rgba(255, 255, 255, 0.06);
      color: #fff
    }

    .sidebar small {
      opacity: .85
    }

    /* CONTENT */
    .main {
      flex: 1;
      min-height: 100vh
    }

    header.topbar {
      background: #fff;
      border-bottom: 1px solid #e9ecef;
      padding: .7rem 1rem
    }

    .search-input {
      max-width: 520px
    }

    /* CARDS */
    .card-ghost {
      background: #fff;
      border: 0;
      border-radius: var(--card-radius);
      box-shadow: 0 8px 20px rgba(18, 22, 31, 0.06)
    }

    /* small layout tweaks */
    .stat .label {
      color: var(--muted);
      font-size: .85rem
    }

    .stat .value {
      font-weight: 700;
      font-size: 1.25rem
    }

    /* responsive: collapse sidebar */
    .sidebar.collapsed {
      width: 72px
    }

    .sidebar.collapsed .label-text {
      display: none
    }

    .sidebar.collapsed .brand .title {
      display: none
    }

    @media (max-width: 991.98px) {
      .sidebar {
        position: fixed;
        z-index: 1040;
        transform: translateX(-100%);
        transition: transform .25s
      }

      .sidebar.show {
        transform: translateX(0)
      }

      body.sidebar-open {
        overflow: hidden
      }
    }

    /* Table avatar */
    .avatar-sm {
      width: 36px;
      height: 36px;
      border-radius: 8px;
      object-fit: cover
    }
  </style>
</head>

<body>
  <div class="d-flex">
    <!-- SIDEBAR -->
    <aside class="sidebar" id="sidebar">
      <div class="brand px-2">
        <div class="logo text-white">M</div>
        <div>
          <div class="title fs-5 fw-bold">Mensa Classes</div>
          <small>Admin Panel</small>
        </div>
      </div>

      <nav class="nav flex-column px-1">
        <a class="nav-link active d-flex align-items-center" href="/"><i class="bi bi-speedometer2 me-3"></i><span
            class="label-text">Slider</span></a>
        <a class="nav-link d-flex align-items-center" href="/about-us"><i class="bi bi-info-circle me-3"></i><span
            class="label-text">About Us</span></a>
        <a class="nav-link d-flex align-items-center" href="/courses"><i class="bi bi-book me-3"></i><span
            class="label-text">Courses</span></a>
        <a class="nav-link d-flex align-items-center" href="/timetable"><i class="bi bi-calendar2-week me-3"></i><span
            class="label-text">Time Table</span></a>
        <a class="nav-link d-flex align-items-center" href="/result"><i class="bi bi-bar-chart-line me-3"></i><span
            class="label-text">Result</span></a>
        <a class="nav-link d-flex align-items-center" href="/testimonials"><i class="bi bi-chat-quote me-3"></i><span
            class="label-text">Testimonials</span></a>
        <a class="nav-link d-flex align-items-center" href="/why-choose-us"><i class="bi bi-people me-3"></i><span
            class="label-text">Why Choose Us</span></a>
        <a class="nav-link mt-2 d-flex align-items-center text-danger" href="#"><i class="bi bi-box-arrow-right me-3"></i><span class="label-text">Logout</span></a>
      </nav>

      <div class="px-2 mt-4">
        <small class="text-white-50">Quick Actions</small>
        <div class="d-grid gap-2 mt-2">
          <button class="btn btn-sm btn-light">+ Add Student</button>
          <button class="btn btn-sm btn-outline-light">New Announcement</button>
        </div>
      </div>
    </aside>

    <!-- MAIN -->
    <div class="main d-flex flex-column">
      <!-- TOPBAR -->
      <header class="topbar d-flex align-items-center justify-content-between">
        <div class="d-flex align-items-center gap-2">
          <button class="btn btn-outline-secondary d-lg-none" id="mobileToggle"><i class="bi bi-list"></i></button>
          <button class="btn btn-outline-secondary" id="toggleSidebar"><i class="bi bi-layout-sidebar"></i></button>
          <h5 class="mb-0">Dashboard</h5>
        </div>

        <div class="d-flex align-items-center gap-3">
          <div class="input-group search-input d-none d-md-flex">
            <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
            <input class="form-control" id="globalSearch" placeholder="Search students, courses, assignments...">
          </div>

          <div class="dropdown">
            <a class="text-dark text-decoration-none d-flex align-items-center" href="#" id="userMenu"
              data-bs-toggle="dropdown" aria-expanded="false">
              <img src="https://avatars.dicebear.com/api/initials/MC.svg" width="36" height="36"
                class="rounded-circle me-2" alt="avatar">
              <div class="d-none d-md-block text-end">
                <div class="fw-bold">Admin</div>
                <div class="small text-muted">Mensa Classes</div>
              </div>
            </a>
            <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userMenu">
              <li><a class="dropdown-item" href="#">Profile</a></li>
              <li><a class="dropdown-item" href="#">Settings</a></li>
              <li>
                <hr class="dropdown-divider">
              </li>
              <li><a class="dropdown-item text-danger" href="#">Sign out</a></li>
            </ul>
          </div>
        </div>
      </header>

      <!-- PAGE CONTENT -->
      <main class="p-4">
        <div class="container-fluid">
          <!-- Welcome + stats -->
          <div class="d-flex align-items-start justify-content-between mb-3 gap-3">
            <div class="flex-grow-1">
              <div class="card card-ghost p-3 mb-3">
                <div class="d-flex align-items-center justify-content-between">

